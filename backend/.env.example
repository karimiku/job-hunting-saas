POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=job_hunting_dev
POSTGRES_HOST=db
POSTGRES_PORT=15432
PORT=8080

# Firebase Admin SDK
# FIREBASE_PROJECT_ID: Firebase コンソール > プロジェクト設定 > プロジェクト ID
FIREBASE_PROJECT_ID=your-firebase-project-id
# サービスアカウント JSON のパス（docker-compose で /app/secrets/ に bind される）
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/serviceAccount.json

# フロントエンドからの Cookie 付きリクエストを許可するオリジン
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ローカル HTTP 開発では false、本番 HTTPS では true
COOKIE_SECURE=false
