POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=job_hunting_dev
POSTGRES_HOST=db
POSTGRES_PORT=15432
PORT=8080

# Supabase Auth / Postgres migration target.
# Example:
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_AUTH_ISSUER=https://<project-ref>.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_URL=
SUPABASE_AUTH_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
# Vercel/Supabase production runtime should provide DATABASE_URL separately.
# Prefer Supabase pooler transaction mode (:6543) for autoscaled Vercel runtime.
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require
PGPOOL_MAX_CONNS=4
PGPOOL_MIN_CONNS=0
PGPOOL_MAX_CONN_IDLE_TIME=60s
PGPOOL_MAX_CONN_LIFETIME=30m
PGPOOL_HEALTH_CHECK_PERIOD=30s
PGX_DEFAULT_QUERY_EXEC_MODE=exec
PGAPPNAME=job-hunting-saas-api

# Legacy Firebase Admin SDK rollback path. Supabase-only runtime leaves these unset.
# FIREBASE_PROJECT_ID=your-firebase-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/serviceAccount.json

# フロントエンドからのリクエストを許可するオリジン。Vercel preview は wildcard host pattern を使える。
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app

# ローカル HTTP 開発では false、本番 HTTPS では true
COOKIE_SECURE=false

# ローカルUI確認用。true のとき /dev/session で Google OAuth なしの開発用セッションを発行する。
# 任意 email でセッションを発行できるため本番では絶対に true にしない（既定 false）。
# ローカルで使うときだけ true に変える。
DEV_AUTH_ENABLED=false

# integration test の schema reset を remote DB に向ける場合だけ明示する。通常は設定しない。
# ALLOW_DESTRUCTIVE_INTEGRATION_TEST_DB=true
