# ============================================================
# サプライチェーン対策 (pnpm 10+)
# ============================================================

# 公開から 4320 分（3日）経過したバージョンのみインストール対象とする。
# 即日公開された悪性パッケージ（chalk/debug 等の近年の事例）を弾く最大の一撃。
# https://pnpm.io/settings#minimumreleaseage
minimum-release-age=4320

# engines.node / engines.pnpm を満たさない環境ではインストール失敗させる
engine-strict=true

# peer dependencies の自動解決（React 等のバージョン不整合で install が詰まるのを避ける）
auto-install-peers=true

# マルチプラットフォーム対応。lockfile に darwin / linux 両方の optional deps を記録して
# Docker (linux) でも macOS (darwin) でもどちらでも `--frozen-lockfile` が通るようにする
supported-architectures.os[]=darwin
supported-architectures.os[]=linux
supported-architectures.cpu[]=arm64
supported-architectures.cpu[]=x64
supported-architectures.libc[]=glibc
